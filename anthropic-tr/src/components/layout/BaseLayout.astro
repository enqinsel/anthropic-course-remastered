---
import { SEO } from 'astro-seo';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  schema?: object;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonical,
  type = 'website',
  schema,
} = Astro.props;

const siteUrl = 'https://anthropic-tr.com';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const adSenseId = import.meta.env.ADSENSE_CLIENT_ID;
const analyticsUrl = import.meta.env.ANALYTICS_URL;
const analyticsSiteId = import.meta.env.ANALYTICS_SITE_ID;
const analyticsProvider = analyticsUrl?.toLowerCase().includes('plausible') ? 'plausible' : 'umami';
---

<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (() => {
      try {
        const stored = window.localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const theme = stored === 'light' || stored === 'dark' ? stored : systemTheme;
        const root = document.documentElement;
        root.classList.remove('light', 'dark');
        root.classList.add(theme);
        root.style.colorScheme = theme;
      } catch {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    })();
  </script>

  <SEO
    title={`${title} | Anthropic TR`}
    description={description}
    canonical={canonicalURL}
    openGraph={{
      basic: {
        title,
        type,
        image: image.startsWith('http') ? image : `${siteUrl}${image}`,
      },
      optional: { description, locale: 'tr_TR', siteName: 'Anthropic TR' },
    }}
    twitter={{ card: 'summary_large_image', title, description }}
    extend={{
      meta: [{ name: 'theme-color', content: '#0f0f13' }],
    }}
  />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  {adSenseId && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adSenseId}`}
      crossorigin="anonymous"
    />
  )}

  {analyticsUrl && analyticsSiteId && analyticsProvider === 'plausible' && (
    <script defer data-domain={analyticsSiteId} src={analyticsUrl} />
  )}

  {analyticsUrl && analyticsSiteId && analyticsProvider === 'umami' && (
    <script defer data-website-id={analyticsSiteId} src={analyticsUrl} />
  )}
</head>
<body class="site-shell">
  <Header />
  <main class="site-main">
    <slot />
  </main>
  <Footer />
  <script define:vars={{ analyticsProviderValue: analyticsProvider ?? '' }}>
    const analyticsProvider = analyticsProviderValue;

    window.trackEvent = function (name, data = {}) {
      try {
        if (analyticsProvider === 'plausible' && typeof window.plausible === 'function') {
          window.plausible(name, Object.keys(data).length ? { props: data } : undefined);
          return;
        }

        if (window.umami && typeof window.umami.track === 'function') {
          window.umami.track(name, data);
        }
      } catch {
        // no-op
      }
    };

    const copyTimers = new WeakMap();

    document.addEventListener('click', async (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const button = target ? target.closest('.copy-btn') : null;
      if (!button) return;

      const directValue = button.dataset.copy;
      const targetSelector = button.dataset.copyTarget;
      const sourceElement = targetSelector ? document.querySelector(targetSelector) : null;
      const textToCopy = directValue
        ?? (sourceElement instanceof HTMLTextAreaElement || sourceElement instanceof HTMLInputElement
          ? sourceElement.value
          : sourceElement?.textContent?.trim()
        );

      if (!textToCopy) return;

      event.preventDefault();

      const defaultLabel = button.dataset.defaultLabel || button.textContent?.trim() || 'Kopyala';
      const successLabel = button.dataset.successLabel || 'Kopyalandı';
      const failureLabel = button.dataset.failureLabel || 'Kopyalanamadı';

      try {
        await navigator.clipboard.writeText(textToCopy);
        button.textContent = successLabel;
        window.trackEvent?.('code_copy', { kind: button.dataset.copyType || 'generic' });
      } catch {
        button.textContent = failureLabel;
      }

      button.disabled = true;
      const previousTimer = copyTimers.get(button);
      if (previousTimer) window.clearTimeout(previousTimer);

      const nextTimer = window.setTimeout(() => {
        button.textContent = defaultLabel;
        button.disabled = false;
      }, 1600);

      copyTimers.set(button, nextTimer);
    });
  </script>
</body>
</html>
