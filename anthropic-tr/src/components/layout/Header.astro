---
const navLinks = [
  { href: '/kurslar', label: 'Kurslar' },
  { href: '/blog', label: 'Blog' },
  { href: '/sss', label: 'SSS' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-surface/80 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline hover:no-underline">
      <div class="w-7 h-7 bg-accent rounded-md flex items-center justify-center text-white text-sm font-bold">A</div>
      <span class="text-sm font-normal text-base">Anthropic <span class="text-muted">TR</span></span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm no-underline transition-colors',
            currentPath.startsWith(link.href)
              ? 'text-accent-light'
              : 'text-muted hover:text-base'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Sağ -->
    <div class="flex items-center gap-3">
      <a href="https://github.com/anthropics/courses" target="_blank" rel="noopener" class="text-muted hover:text-base no-underline" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>

      <!-- Mobil hamburger -->
      <button class="md:hidden text-muted" id="menu-toggle" aria-label="Menü">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobil menü -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface">
    {navLinks.map(link => (
      <a href={link.href} class="block px-4 py-3 text-sm text-muted hover:text-base no-underline border-b border-border">
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
