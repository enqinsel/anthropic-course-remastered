---
export const prerender = false;
import { supabase } from '../../lib/supabase';

const { data: posts } = await supabase
  .from('posts')
  .select('id, title, status, created_at, published_at')
  .order('created_at', { ascending: false });

const published = posts?.filter(p => p.status === 'published').length ?? 0;
const drafts = posts?.filter(p => p.status === 'draft').length ?? 0;
---

<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Panel | Anthropic TR</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f0f13; color: #e8e6df; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; padding: 2rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 12px; }
    h1 { font-size: 1.4rem; font-weight: normal; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 2rem; }
    .stat { background: #18181f; border: 1px solid #2e2e3a; border-radius: 8px; padding: 1rem; }
    .stat-num { font-size: 1.8rem; font-weight: 300; }
    .stat-label { font-size: 11px; color: #888; margin-top: 4px; }
    .btn { background: #c96442; color: white; border: none; border-radius: 6px; padding: 8px 16px; font-size: 13px; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn:hover { background: #e88060; }
    .btn-sm { padding: 4px 10px; font-size: 11px; }
    .btn-ghost { background: transparent; border: 1px solid #2e2e3a; color: #888; }
    .btn-ghost:hover { border-color: #c96442; color: #e88060; }
    .btn-danger { border-color: #e24b4a; color: #e24b4a; }
    .btn-danger:hover { background: rgba(226,75,74,0.1); }
    .card { background: #18181f; border: 1px solid #2e2e3a; border-radius: 10px; padding: 1.5rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #2e2e3a; font-size: 13px; }
    th { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; }
    .badge-pub { background: rgba(74,159,111,0.15); color: #4a9f6f; }
    .badge-draft { background: rgba(136,136,128,0.15); color: #888; }
    .actions { display: flex; gap: 6px; }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1>Admin Panel</h1>
      <p style="color:#888;font-size:13px;margin-top:4px;">Anthropic TR</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <a href="/admin/blog-editor" class="btn">+ Yeni Yazı</a>
      <a href="/admin/faq-manager" class="btn btn-ghost">SSS Yönet</a>
      <button id="logout-btn" class="btn btn-ghost btn-sm">Çıkış</button>
    </div>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="stat-num">{posts?.length ?? 0}</div>
      <div class="stat-label">Toplam Yazı</div>
    </div>
    <div class="stat">
      <div class="stat-num">{published}</div>
      <div class="stat-label">Yayında</div>
    </div>
    <div class="stat">
      <div class="stat-num">{drafts}</div>
      <div class="stat-label">Taslak</div>
    </div>
  </div>

  <div class="card">
    {posts && posts.length > 0 ? (
      <table>
        <thead>
          <tr><th>Başlık</th><th>Durum</th><th>Tarih</th><th>İşlem</th></tr>
        </thead>
        <tbody>
          {posts.map(post => (
            <tr>
              <td>{post.title}</td>
              <td>
                <span class={`badge ${post.status === 'published' ? 'badge-pub' : 'badge-draft'}`}>
                  {post.status === 'published' ? 'Yayında' : 'Taslak'}
                </span>
              </td>
              <td style="color:#888">{new Date(post.created_at).toLocaleDateString('tr-TR')}</td>
              <td>
                <div class="actions">
                  <a href={`/admin/blog-editor?id=${post.id}`} class="btn btn-ghost btn-sm">Düzenle</a>
                  <button class="btn btn-ghost btn-sm btn-danger" data-delete-id={post.id}>Sil</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <p style="color:#888;text-align:center;padding:2rem;">Henüz yazı yok. <a href="/admin/blog-editor" style="color:#c96442;">İlk yazıyı oluştur →</a></p>
    )}
  </div>

  <script>
    // Çıkış
    document.getElementById('logout-btn')?.addEventListener('click', () => {
      document.cookie = 'sb-access-token=; max-age=0; path=/';
      document.cookie = 'sb-refresh-token=; max-age=0; path=/';
      window.location.href = '/admin/login';
    });

    // Sil butonları
    document.querySelectorAll<HTMLButtonElement>('[data-delete-id]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.deleteId;
        if (!id || !confirm('Bu yazıyı silmek istediğine emin misin?')) return;
        const resp = await fetch('/api/posts', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (resp.ok) window.location.reload();
        else alert('Silme işlemi başarısız.');
      });
    });
  </script>
</body>
</html>
