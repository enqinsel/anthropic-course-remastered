---
export const prerender = false;
const postId = Astro.url.searchParams.get('id') ?? '';
---

<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog Editörü | Anthropic TR</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f0f13; color: #e8e6df; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #18181f; border-bottom: 1px solid #2e2e3a; padding: 0 1.5rem; height: 50px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .btn { background: #c96442; color: white; border: none; border-radius: 6px; padding: 7px 14px; font-size: 12px; cursor: pointer; }
    .btn:hover { background: #e88060; }
    .btn-ghost { background: transparent; border: 1px solid #2e2e3a; color: #888; }
    .btn-ghost:hover { border-color: #c96442; color: #e88060; }
    .editor-layout { display: flex; flex: 1; overflow: hidden; }
    .meta-panel { width: 280px; background: #18181f; border-right: 1px solid #2e2e3a; overflow-y: auto; padding: 1.5rem; flex-shrink: 0; }
    .blocks-panel { flex: 1; overflow-y: auto; padding: 1.5rem; }
    label { display: block; font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 5px; margin-top: 14px; }
    input, textarea, select { width: 100%; background: #22222c; border: 1px solid #2e2e3a; border-radius: 6px; padding: 8px 10px; color: #e8e6df; font-size: 13px; font-family: inherit; outline: none; }
    input:focus, textarea:focus, select:focus { border-color: #c96442; }
    textarea { resize: vertical; }
    .char-count { font-size: 11px; color: #888; text-align: right; margin-top: 3px; }
    .block-item { background: #18181f; border: 1px solid #2e2e3a; border-radius: 8px; padding: 14px; margin-bottom: 10px; }
    .block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .block-type { font-size: 11px; color: #c96442; text-transform: uppercase; letter-spacing: 0.05em; }
    .block-actions { display: flex; gap: 6px; }
    .add-block-menu { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 1rem; }
    .add-block-btn { background: #22222c; border: 1px dashed #2e2e3a; border-radius: 6px; padding: 10px 6px; font-size: 11px; text-align: center; cursor: pointer; color: #888; transition: all 0.15s; }
    .add-block-btn:hover { border-color: #c96442; color: #e88060; }
    .toast { position: fixed; bottom: 20px; right: 20px; background: #4a9f6f; color: white; padding: 10px 18px; border-radius: 6px; font-size: 13px; opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 999; }
    .toast.show { opacity: 1; }
    .status-toggle { display: flex; gap: 8px; margin-top: 6px; }
    .status-opt { flex: 1; padding: 7px; border: 1px solid #2e2e3a; border-radius: 6px; font-size: 12px; text-align: center; cursor: pointer; background: transparent; color: #888; }
    .status-opt.active { border-color: #c96442; color: #c96442; background: rgba(201,100,66,0.1); }
  </style>
</head>
<body>
  <!-- postId'yi DOM'a göm -->
  <input type="hidden" id="post-id" value={postId} />

  <div class="topbar">
    <div style="display:flex;align-items:center;gap:12px;">
      <a href="/admin" style="color:#888;text-decoration:none;font-size:12px;">← Admin</a>
      <span id="topbar-title" style="font-size:13px;color:#888;">{postId ? 'Yazı Düzenle' : 'Yeni Yazı'}</span>
      <span id="autosave-status" style="font-size:11px;color:#888;"></span>
    </div>
    <div style="display:flex;gap:8px;">
      <button class="btn btn-ghost" id="save-draft">Taslak Kaydet</button>
      <button class="btn" id="save-publish">Yayınla</button>
    </div>
  </div>

  <div class="editor-layout">
    <!-- Sol: Meta -->
    <div class="meta-panel">
      <label>Başlık</label>
      <input type="text" id="title" placeholder="Yazı başlığı..." />

      <label>Slug</label>
      <input type="text" id="slug" placeholder="yazi-basligi" />

      <label>Özet</label>
      <textarea id="excerpt" rows="3" placeholder="Kısa açıklama..."></textarea>

      <label>Kapak Görseli URL</label>
      <input type="url" id="cover_image" placeholder="https://..." />
      <div id="cover-preview" style="margin-top:6px;display:none;">
        <img id="cover-img" style="width:100%;border-radius:6px;aspect-ratio:16/9;object-fit:cover;" alt="Kapak" />
      </div>

      <label>Etiketler (virgülle ayır)</label>
      <input type="text" id="tags" placeholder="claude, api, prompt" />

      <label>SEO Başlığı</label>
      <input type="text" id="seo_title" placeholder="Opsiyonel..." />

      <label>SEO Açıklaması</label>
      <textarea id="seo_description" rows="3" placeholder="Maks 160 karakter..."></textarea>
      <div class="char-count" id="seo-count">0/160</div>

      <label>Durum</label>
      <div class="status-toggle">
        <button class="status-opt active" id="status-draft">Taslak</button>
        <button class="status-opt" id="status-published">Yayında</button>
      </div>
    </div>

    <!-- Sağ: Bloklar -->
    <div class="blocks-panel">
      <div id="blocks-container"></div>
      <div style="margin-top:1rem;">
        <div style="font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Blok Ekle</div>
        <div class="add-block-menu">
          <button class="add-block-btn" id="add-paragraph">📝 Paragraf</button>
          <button class="add-block-btn" id="add-heading">🔤 Başlık</button>
          <button class="add-block-btn" id="add-image">🖼 Resim</button>
          <button class="add-block-btn" id="add-code">💻 Kod</button>
          <button class="add-block-btn" id="add-callout">💡 Callout</button>
          <button class="add-block-btn" id="add-quote">💬 Alıntı</button>
          <button class="add-block-btn" id="add-video">▶️ Video</button>
          <button class="add-block-btn" id="add-divider">── Ayraç</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const postId = (document.getElementById('post-id') as HTMLInputElement).value || null;
    let blocks: any[] = [];
    let postStatus = 'draft';
    let currentPostId: string | null = postId;
    let autosaveTimer: ReturnType<typeof setTimeout> | null = null;

    // --- Utils ---
    function showToast(msg: string, ok = true) {
      const t = document.getElementById('toast')!;
      t.textContent = msg;
      t.style.background = ok ? '#4a9f6f' : '#e24b4a';
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    function setStatus(s: string) {
      postStatus = s;
      document.getElementById('status-draft')!.classList.toggle('active', s === 'draft');
      document.getElementById('status-published')!.classList.toggle('active', s === 'published');
    }

    function generateSlug(title: string) {
      return title.toLowerCase()
        .replace(/ğ/g,'g').replace(/ş/g,'s').replace(/ı/g,'i')
        .replace(/ö/g,'o').replace(/ü/g,'u').replace(/ç/g,'c')
        .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }

    // --- Blok Yönetimi ---
    function addBlock(type: string) {
      blocks.push({ id: 'b-' + Date.now(), type });
      renderBlocks();
    }

    function removeBlock(id: string) {
      blocks = blocks.filter(b => b.id !== id);
      renderBlocks();
    }

    function moveBlock(id: string, dir: 'up' | 'down') {
      const i = blocks.findIndex(b => b.id === id);
      if (dir === 'up' && i > 0) [blocks[i-1], blocks[i]] = [blocks[i], blocks[i-1]];
      if (dir === 'down' && i < blocks.length - 1) [blocks[i], blocks[i+1]] = [blocks[i+1], blocks[i]];
      renderBlocks();
    }

    function updateBlock(id: string, field: string, value: any) {
      const block = blocks.find(b => b.id === id);
      if (block) block[field] = value;
      scheduleAutosave();
    }

    function extractVideoId(id: string, url: string) {
      const m = url.match(/(?:v=|youtu\.be\/)([^&\n?#]+)/);
      if (m) updateBlock(id, 'videoId', m[1]);
    }

    function renderBlocks() {
      document.getElementById('blocks-container')!.innerHTML = blocks.map(renderBlock).join('');
      // Re-attach event listeners after innerHTML update
      attachBlockListeners();
    }

    function renderBlock(block: any): string {
      const labels: Record<string,string> = { paragraph:'Paragraf', heading:'Başlık', image:'Resim', code:'Kod', callout:'Callout', quote:'Alıntı', video:'Video', divider:'Ayraç' };
      const acts = `<div class="block-actions">
        <button class="btn btn-ghost" style="padding:2px 8px;font-size:11px;" data-move="${block.id}" data-dir="up">↑</button>
        <button class="btn btn-ghost" style="padding:2px 8px;font-size:11px;" data-move="${block.id}" data-dir="down">↓</button>
        <button class="btn btn-ghost" style="padding:2px 8px;font-size:11px;color:#e24b4a;border-color:#e24b4a;" data-remove="${block.id}">✕</button>
      </div>`;

      const esc = (s: string) => (s || '').replace(/"/g, '&quot;').replace(/</g, '&lt;');
      let fields = '';

      if (block.type === 'paragraph') {
        fields = `<textarea rows="4" placeholder="Paragraf metni..." data-update="${block.id}" data-field="text">${esc(block.text)}</textarea>`;
      } else if (block.type === 'heading') {
        fields = `<select data-update="${block.id}" data-field="level" data-int>
          <option value="2" ${block.level!==3?'selected':''}>H2</option>
          <option value="3" ${block.level===3?'selected':''}>H3</option>
        </select>
        <input type="text" style="margin-top:6px;" placeholder="Başlık metni..." value="${esc(block.text)}" data-update="${block.id}" data-field="text" />`;
      } else if (block.type === 'image') {
        fields = `<input type="url" placeholder="Görsel URL..." value="${esc(block.url)}" data-update="${block.id}" data-field="url" />
        <input type="text" style="margin-top:6px;" placeholder="Alt metin..." value="${esc(block.alt)}" data-update="${block.id}" data-field="alt" />
        <input type="text" style="margin-top:6px;" placeholder="Açıklama (opsiyonel)..." value="${esc(block.caption)}" data-update="${block.id}" data-field="caption" />`;
      } else if (block.type === 'code') {
        const lang = block.language || 'python';
        fields = `<select data-update="${block.id}" data-field="language">
          <option value="python" ${lang==='python'?'selected':''}>Python</option>
          <option value="javascript" ${lang==='javascript'?'selected':''}>JavaScript</option>
          <option value="typescript" ${lang==='typescript'?'selected':''}>TypeScript</option>
          <option value="bash" ${lang==='bash'?'selected':''}>Bash</option>
          <option value="json" ${lang==='json'?'selected':''}>JSON</option>
          <option value="text" ${lang==='text'?'selected':''}>Düz Metin</option>
        </select>
        <textarea rows="6" style="margin-top:6px;font-family:monospace;font-size:12px;" placeholder="Kod..." data-update="${block.id}" data-field="code">${esc(block.code)}</textarea>`;
      } else if (block.type === 'callout') {
        const v = block.variant || 'info';
        fields = `<select data-update="${block.id}" data-field="variant">
          <option value="info" ${v==='info'?'selected':''}>ℹ️ Bilgi</option>
          <option value="warn" ${v==='warn'?'selected':''}>⚠️ Uyarı</option>
          <option value="success" ${v==='success'?'selected':''}>✅ Başarı</option>
        </select>
        <textarea style="margin-top:6px;" rows="3" placeholder="Callout metni..." data-update="${block.id}" data-field="text">${esc(block.text)}</textarea>`;
      } else if (block.type === 'quote') {
        fields = `<textarea rows="3" placeholder="Alıntı metni..." data-update="${block.id}" data-field="text">${esc(block.text)}</textarea>
        <input type="text" style="margin-top:6px;" placeholder="Kaynak (opsiyonel)..." value="${esc(block.source)}" data-update="${block.id}" data-field="source" />`;
      } else if (block.type === 'video') {
        fields = `<input type="url" placeholder="YouTube URL..." value="${block.videoId ? 'https://youtube.com/watch?v=' + block.videoId : ''}" data-video-id="${block.id}" />`;
      } else if (block.type === 'divider') {
        fields = `<div style="border-top:1px solid #2e2e3a;margin:4px 0;"></div>`;
      }

      return `<div class="block-item" id="${block.id}">
        <div class="block-header"><span class="block-type">${labels[block.type]||block.type}</span>${acts}</div>
        ${fields}
      </div>`;
    }

    function attachBlockListeners() {
      // Move/remove
      document.querySelectorAll<HTMLElement>('[data-move]').forEach(el => {
        el.onclick = () => moveBlock(el.dataset.move!, el.dataset.dir as 'up' | 'down');
      });
      document.querySelectorAll<HTMLElement>('[data-remove]').forEach(el => {
        el.onclick = () => removeBlock(el.dataset.remove!);
      });
      // Update fields
      document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[data-update]').forEach(el => {
        el.oninput = el.onchange = () => {
          const val = 'dataset' in el && (el as any).dataset.int ? parseInt(el.value) : el.value;
          updateBlock((el as any).dataset.update, (el as any).dataset.field, val);
        };
      });
      // Video ID extraction
      document.querySelectorAll<HTMLInputElement>('[data-video-id]').forEach(el => {
        el.oninput = () => extractVideoId(el.dataset.videoId!, el.value);
      });
    }

    // --- Autosave ---
    function scheduleAutosave() {
      if (autosaveTimer) clearTimeout(autosaveTimer);
      document.getElementById('autosave-status')!.textContent = 'Kaydediliyor...';
      autosaveTimer = setTimeout(() => savePost(postStatus, true), 30000);
    }

    // --- Save ---
    async function savePost(status: string, isAuto = false) {
      const title = (document.getElementById('title') as HTMLInputElement).value.trim();
      if (!title) { showToast('Başlık zorunlu!', false); return; }

      const tagsRaw = (document.getElementById('tags') as HTMLInputElement).value;
      const tags = tagsRaw.split(',').map((t: string) => t.trim()).filter(Boolean);

      const payload: any = {
        title,
        slug: (document.getElementById('slug') as HTMLInputElement).value || generateSlug(title),
        excerpt: (document.getElementById('excerpt') as HTMLTextAreaElement).value || null,
        cover_image: (document.getElementById('cover_image') as HTMLInputElement).value || null,
        tags,
        content: blocks,
        seo_title: (document.getElementById('seo_title') as HTMLInputElement).value || null,
        seo_description: (document.getElementById('seo_description') as HTMLTextAreaElement).value || null,
        status,
      };

      if (status === 'published' && !currentPostId) {
        payload.published_at = new Date().toISOString();
      }

      const resp = await fetch('/api/posts', {
        method: currentPostId ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...payload, id: currentPostId }),
      });

      if (resp.ok) {
        const data = await resp.json();
        currentPostId = data.id;
        document.getElementById('autosave-status')!.textContent = 'Kaydedildi ✓';
        if (!isAuto) showToast(status === 'published' ? 'Yazı yayınlandı! 🎉' : 'Taslak kaydedildi.');
        setTimeout(() => { document.getElementById('autosave-status')!.textContent = ''; }, 3000);
      } else {
        showToast('Kaydetme hatası!', false);
      }
    }

    // --- Event Bindings ---
    document.getElementById('title')!.addEventListener('input', (e) => {
      const slug = generateSlug((e.target as HTMLInputElement).value);
      (document.getElementById('slug') as HTMLInputElement).value = slug;
    });

    document.getElementById('seo_description')!.addEventListener('input', function() {
      document.getElementById('seo-count')!.textContent = (this as HTMLTextAreaElement).value.length + '/160';
    });

    document.getElementById('cover_image')!.addEventListener('input', function() {
      const v = (this as HTMLInputElement).value;
      const preview = document.getElementById('cover-preview')!;
      if (v) { (document.getElementById('cover-img') as HTMLImageElement).src = v; preview.style.display = 'block'; }
      else { preview.style.display = 'none'; }
    });

    document.getElementById('status-draft')!.onclick = () => setStatus('draft');
    document.getElementById('status-published')!.onclick = () => setStatus('published');
    document.getElementById('save-draft')!.onclick = () => savePost('draft');
    document.getElementById('save-publish')!.onclick = () => savePost('published');

    // Add block buttons
    const blockTypes = ['paragraph','heading','image','code','callout','quote','video','divider'];
    blockTypes.forEach(type => {
      document.getElementById(`add-${type}`)!.onclick = () => addBlock(type);
    });

    // --- Mevcut yazıyı yükle ---
    if (postId) {
      fetch(`/api/posts/${postId}`).then(r => r.json()).then((post: any) => {
        (document.getElementById('title') as HTMLInputElement).value = post.title || '';
        (document.getElementById('slug') as HTMLInputElement).value = post.slug || '';
        (document.getElementById('excerpt') as HTMLTextAreaElement).value = post.excerpt || '';
        (document.getElementById('cover_image') as HTMLInputElement).value = post.cover_image || '';
        (document.getElementById('tags') as HTMLInputElement).value = (post.tags ?? []).join(', ');
        (document.getElementById('seo_title') as HTMLInputElement).value = post.seo_title || '';
        (document.getElementById('seo_description') as HTMLTextAreaElement).value = post.seo_description || '';
        document.getElementById('seo-count')!.textContent = (post.seo_description || '').length + '/160';
        blocks = post.content ?? [];
        setStatus(post.status || 'draft');
        renderBlocks();
        if (post.cover_image) {
          (document.getElementById('cover-img') as HTMLImageElement).src = post.cover_image;
          document.getElementById('cover-preview')!.style.display = 'block';
        }
      });
    }
  </script>
</body>
</html>
