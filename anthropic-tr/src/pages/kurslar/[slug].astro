---
export const prerender = false;

import { getCourseBySlug, getCourseChapterHref } from '../../lib/courseData';

const { slug } = Astro.params;
const course = slug ? getCourseBySlug(slug) : undefined;

if (!course || course.chapters.length === 0) {
  return Astro.redirect('/404', 302);
}

const requestedChapter = Astro.url.searchParams.get('chapter');
const targetChapter = course.chapters.find((chapter) => chapter.slug === requestedChapter) ?? course.chapters[0];
const targetPath = getCourseChapterHref(course.slug, targetChapter?.slug);

return Astro.redirect(targetPath, requestedChapter ? 301 : 302);
---
