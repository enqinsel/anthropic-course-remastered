---
export const prerender = true;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AdBanner from '../../components/ads/AdBanner.astro';
import type { Chapter } from '../../lib/types';

interface CourseJson {
  course_id: string;
  title_tr: string;
  slug: string;
  description_tr: string | null;
  chapters: Chapter[];
  source_url: string | null;
  last_synced_at: string | null;
}

export async function getStaticPaths() {
  const courseFiles = import.meta.glob<{ default: CourseJson }>('../../content/courses/*.json', { eager: true });
  const courses = Object.values(courseFiles).map(m => m.default);
  return courses.map(course => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props as { course: CourseJson };
const chapters: Chapter[] = Array.isArray(course.chapters) ? course.chapters : [];

const activeSlug = Astro.url.searchParams.get('chapter') ?? chapters[0]?.slug;
const activeChapter = chapters.find(ch => ch.slug === activeSlug) ?? chapters[0];
const activeIndex = activeChapter ? chapters.indexOf(activeChapter) : -1;

const schema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": course.title_tr,
  "description": course.description_tr ?? course.title_tr,
  "provider": { "@type": "Organization", "name": "Anthropic TR", "url": "https://anthropic-tr.com" },
  "inLanguage": "tr",
  "isAccessibleForFree": true,
  "educationalLevel": "beginner",
  "url": `https://anthropic-tr.com/kurslar/${course.slug}`,
};
---

<BaseLayout
  title={course.title_tr}
  description={course.description_tr ?? `${course.title_tr} — Türkçe kurs materyali`}
  schema={schema}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-xs text-muted mb-6">
      <a href="/" class="hover:text-base no-underline">Ana Sayfa</a>
      <span class="mx-2">›</span>
      <a href="/kurslar" class="hover:text-base no-underline">Kurslar</a>
      <span class="mx-2">›</span>
      <span>{course.title_tr}</span>
    </nav>

    <div class="flex gap-8">
      <!-- SOL: Sidebar -->
      <aside class="w-64 flex-shrink-0 hidden lg:block">
        <div class="sticky top-20">
          <h2 class="text-xs text-muted uppercase tracking-widest mb-4">Bölümler</h2>

          {chapters.length > 0 ? (
            <nav class="space-y-1" id="chapter-nav">
              {chapters.map(ch => (
                <a
                  href={`/kurslar/${course.slug}?chapter=${ch.slug}`}
                  data-chapter-slug={ch.slug}
                  class:list={[
                    'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors no-underline chapter-link',
                    ch.slug === activeChapter?.slug
                      ? 'bg-surface2 text-accent-light border-l-2 border-accent'
                      : 'text-muted hover:text-base hover:bg-surface2'
                  ]}
                >
                  <span class="text-xs font-mono text-muted w-6 flex-shrink-0">{String(ch.order_index).padStart(2, '0')}</span>
                  <span class="flex-1 leading-snug lang-tr">{ch.title_tr}</span>
                  <span class="flex-1 leading-snug lang-en hidden">{ch.title}</span>
                  <span class="done-check hidden text-success text-xs">✓</span>
                </a>
              ))}
            </nav>
          ) : (
            <p class="text-xs text-muted leading-relaxed">
              Bölümler henüz yüklenmedi.<br/>
              <code class="block mt-2 text-xs">python scripts/content_agent.py</code>
            </p>
          )}

          <div class="mt-6">
            <AdBanner slot="1111111111" format="rectangle" />
          </div>
        </div>
      </aside>

      <!-- SAĞ: İçerik -->
      <div class="flex-1 min-w-0">
        {chapters.length > 0 && (
          <div class="mb-6 bg-surface border border-border rounded-lg p-4">
            <div class="flex justify-between text-xs text-muted mb-2">
              <span>İlerleme</span>
              <span id="progress-text">0 / {chapters.length}</span>
            </div>
            <div class="h-1 bg-surface2 rounded-full overflow-hidden">
              <div id="progress-bar" class="h-full bg-accent rounded-full transition-all" style="width:0%" />
            </div>
          </div>
        )}

        {activeChapter ? (
          <article>
            <!-- Başlık + Dil Toggle -->
            <div class="mb-6 flex items-start justify-between gap-4">
              <div>
                <span class="text-xs text-accent uppercase tracking-widest">Bölüm {activeChapter.order_index}</span>
                <h1 class="text-2xl font-light mt-2 lang-tr">{activeChapter.title_tr}</h1>
                <h1 class="text-2xl font-light mt-2 lang-en hidden">{activeChapter.title}</h1>
              </div>
              <div class="flex items-center gap-1 bg-surface border border-border rounded-lg p-1 flex-shrink-0 mt-1">
                <button id="lang-tr" class="text-xs px-3 py-1.5 rounded-md transition-colors bg-accent text-white">TR</button>
                <button id="lang-en" class="text-xs px-3 py-1.5 rounded-md transition-colors text-muted hover:text-base">EN</button>
              </div>
            </div>

            <!-- İçerik TR -->
            <div class="lang-tr space-y-4">
              {(activeChapter.blocks_tr ?? []).length > 0 ? (
                (activeChapter.blocks_tr ?? []).map(block =>
                  block.type === 'html'
                    ? <div class="prose-content leading-relaxed" set:html={block.content} />
                    : <pre class="my-4 overflow-x-auto text-sm"><code>{block.content}</code></pre>
                )
              ) : (
                <p class="text-muted text-sm">İçerik henüz yüklenmedi. <code>python scripts/content_agent.py</code> çalıştırın.</p>
              )}
            </div>

            <!-- İçerik EN -->
            <div class="lang-en hidden space-y-4">
              {(activeChapter.blocks_en ?? []).length > 0 ? (
                (activeChapter.blocks_en ?? []).map(block =>
                  block.type === 'html'
                    ? <div class="prose-content leading-relaxed" set:html={block.content} />
                    : <pre class="my-4 overflow-x-auto text-sm"><code>{block.content}</code></pre>
                )
              ) : (
                <p class="text-muted text-sm">Content not loaded yet.</p>
              )}
            </div>

            <!-- Önceki / Tamamla / Sonraki -->
            <div class="flex justify-between items-center mt-10 pt-6 border-t border-border">
              {activeIndex > 0 ? (
                <a href={`/kurslar/${course.slug}?chapter=${chapters[activeIndex - 1].slug}`}
                   class="text-sm text-muted hover:text-base no-underline flex items-center gap-2">
                  ← <span class="lang-tr">{chapters[activeIndex - 1].title_tr}</span>
                     <span class="lang-en hidden">{chapters[activeIndex - 1].title}</span>
                </a>
              ) : <span />}

              <button
                id="mark-done"
                data-chapter-slug={activeChapter.slug}
                data-course-id={course.course_id}
                class="bg-accent hover:bg-accent-light text-white px-4 py-2 rounded-lg text-sm transition-colors"
              >
                Tamamla ✓
              </button>

              {activeIndex < chapters.length - 1 ? (
                <a href={`/kurslar/${course.slug}?chapter=${chapters[activeIndex + 1].slug}`}
                   class="text-sm text-muted hover:text-base no-underline flex items-center gap-2">
                  <span class="lang-tr">{chapters[activeIndex + 1].title_tr}</span>
                  <span class="lang-en hidden">{chapters[activeIndex + 1].title}</span> →
                </a>
              ) : <span />}
            </div>
          </article>
        ) : (
          <div class="py-16 text-center">
            <h1 class="text-2xl font-light mb-4">{course.title_tr}</h1>
            {course.description_tr && (
              <p class="text-muted mb-6 max-w-md mx-auto">{course.description_tr}</p>
            )}
            <div class="bg-surface border border-border rounded-lg p-6 max-w-md mx-auto text-left">
              <p class="text-sm text-muted mb-2">İçerik henüz yüklenmemiş.</p>
              <pre class="text-xs"><code>python scripts/content_agent.py</code></pre>
            </div>
            {course.source_url && (
              <a href={course.source_url} target="_blank" rel="noopener" class="text-sm text-accent mt-4 block">
                GitHub'da kaynak →
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .prose-content :global(h1) { font-size: 1.5rem; font-weight: 300; margin: 1.5rem 0 0.75rem; }
  .prose-content :global(h2) { font-size: 1.2rem; font-weight: 400; margin: 1.25rem 0 0.5rem; border-left: 2px solid var(--color-accent); padding-left: 0.75rem; }
  .prose-content :global(h3) { font-size: 1rem; font-weight: 600; margin: 1rem 0 0.4rem; color: var(--color-accent-light); }
  .prose-content :global(p) { margin-bottom: 0.75rem; }
  .prose-content :global(ul), .prose-content :global(ol) { padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .prose-content :global(li) { margin-bottom: 0.25rem; }
  .prose-content :global(code) { font-family: var(--font-mono); font-size: 0.875em; background: var(--color-surface2); padding: 0.1em 0.35em; border-radius: 3px; }
  .prose-content :global(pre) { background: var(--color-surface2); border: 1px solid var(--color-border); border-radius: 0.5rem; padding: 1rem; overflow-x: auto; margin: 1rem 0; }
  .prose-content :global(pre code) { background: none; padding: 0; }
  .prose-content :global(blockquote) { border-left: 3px solid var(--color-border); padding-left: 1rem; color: var(--color-muted); margin: 1rem 0; font-style: italic; }
  .prose-content :global(table) { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.875rem; }
  .prose-content :global(th), .prose-content :global(td) { border: 1px solid var(--color-border); padding: 0.5rem 0.75rem; }
  .prose-content :global(th) { background: var(--color-surface2); font-weight: 500; }
  .prose-content :global(a) { color: var(--color-accent-light); }
  pre { background: var(--color-surface2); border: 1px solid var(--color-border); border-radius: 0.5rem; padding: 1rem; font-family: var(--font-mono); line-height: 1.6; }
</style>

<script>
  const LANG_KEY = 'course-lang';

  function getLang(): 'tr' | 'en' {
    return (localStorage.getItem(LANG_KEY) as 'tr' | 'en') ?? 'tr';
  }

  function applyLang(lang: 'tr' | 'en') {
    document.querySelectorAll<HTMLElement>('.lang-tr').forEach(el => el.classList.toggle('hidden', lang !== 'tr'));
    document.querySelectorAll<HTMLElement>('.lang-en').forEach(el => el.classList.toggle('hidden', lang !== 'en'));
    const btnTr = document.getElementById('lang-tr');
    const btnEn = document.getElementById('lang-en');
    const activeClass = 'text-xs px-3 py-1.5 rounded-md transition-colors bg-accent text-white';
    const inactiveClass = 'text-xs px-3 py-1.5 rounded-md transition-colors text-muted hover:text-base';
    if (btnTr) btnTr.className = lang === 'tr' ? activeClass : inactiveClass;
    if (btnEn) btnEn.className = lang === 'en' ? activeClass : inactiveClass;
    localStorage.setItem(LANG_KEY, lang);
  }

  applyLang(getLang());
  document.getElementById('lang-tr')?.addEventListener('click', () => applyLang('tr'));
  document.getElementById('lang-en')?.addEventListener('click', () => applyLang('en'));

  function getProgress(courseId: string): Set<string> {
    try {
      const raw = localStorage.getItem(`progress-${courseId}`);
      return new Set(raw ? JSON.parse(raw) : []);
    } catch { return new Set(); }
  }

  function saveProgress(courseId: string, done: Set<string>) {
    localStorage.setItem(`progress-${courseId}`, JSON.stringify([...done]));
  }

  function updateUI(courseId: string, total: number) {
    const done = getProgress(courseId);
    const pct = total ? (done.size / total) * 100 : 0;
    const bar = document.getElementById('progress-bar');
    const txt = document.getElementById('progress-text');
    if (bar) bar.style.width = pct + '%';
    if (txt) txt.textContent = `${done.size} / ${total}`;
    document.querySelectorAll<HTMLElement>('.chapter-link').forEach(link => {
      const check = link.querySelector<HTMLElement>('.done-check');
      if (check) check.classList.toggle('hidden', !done.has(link.dataset.chapterSlug ?? ''));
    });
  }

  const btn = document.getElementById('mark-done') as HTMLButtonElement | null;
  if (btn) {
    const chapterSlug = btn.dataset.chapterSlug ?? '';
    const courseId = btn.dataset.courseId ?? '';
    const total = document.querySelectorAll('.chapter-link').length;
    updateUI(courseId, total);
    const done = getProgress(courseId);
    if (done.has(chapterSlug)) {
      btn.textContent = 'Tamamlandı ✓';
      btn.classList.replace('bg-accent', 'bg-success');
    }
    btn.addEventListener('click', () => {
      const current = getProgress(courseId);
      if (current.has(chapterSlug)) {
        current.delete(chapterSlug);
        btn.textContent = 'Tamamla ✓';
        btn.classList.replace('bg-success', 'bg-accent');
      } else {
        current.add(chapterSlug);
        btn.textContent = 'Tamamlandı ✓';
        btn.classList.replace('bg-accent', 'bg-success');
      }
      saveProgress(courseId, current);
      updateUI(courseId, total);
    });
  }
</script>
