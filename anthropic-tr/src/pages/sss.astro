---
export const prerender = true;

import BaseLayout from '../components/layout/BaseLayout.astro';
import faqsData from '../content/faqs.json';

const categoryLabels: Record<string, string> = {
  genel:  'Genel',
  api:    'API ve Teknik',
  prompt: 'Prompt Mühendisliği',
  arac:   'Araç Kullanımı',
};

const grouped = faqsData.reduce<Record<string, typeof faqsData>>((acc, faq) => {
  if (!acc[faq.category]) acc[faq.category] = [];
  acc[faq.category].push(faq);
  return acc;
}, {});

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqsData.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Sık Sorulan Sorular — Claude ve Anthropic API"
  description="Claude, Anthropic API, prompt mühendisliği ve araç kullanımı hakkında sık sorulan soruların Türkçe cevapları."
  schema={schema}
>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <div class="mb-10">
      <h1 class="text-3xl font-light mb-3">Sık Sorulan Sorular</h1>
      <p class="text-muted max-w-xl">Claude, Anthropic API ve yapay zeka konularında
      merak ettiklerinizi burada cevaplıyoruz.</p>
    </div>

    <!-- Anlık arama -->
    <div class="mb-8">
      <input
        type="text"
        id="faq-search"
        placeholder="Soruları ara..."
        class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm outline-none focus:border-accent transition-colors"
      />
    </div>

    <!-- Kategori linkleri -->
    <div class="flex flex-wrap gap-2 mb-10">
      {Object.keys(grouped).map(cat => (
        <a
          href={`#${cat}`}
          class="text-xs bg-surface border border-border rounded-full px-4 py-1.5 text-muted hover:border-accent no-underline transition-colors"
        >
          {categoryLabels[cat] ?? cat}
          <span class="ml-1 opacity-50">({grouped[cat].length})</span>
        </a>
      ))}
    </div>

    <!-- Kategoriler -->
    {Object.entries(grouped).map(([cat, items]) => (
      <section id={cat} class="mb-10">
        <h2 class="text-sm font-medium text-accent-light mb-4 pb-3 border-b border-border uppercase tracking-widest">
          {categoryLabels[cat] ?? cat}
        </h2>
        <div class="space-y-2">
          {items.map(faq => (
            <details
              class="group border border-border rounded-xl overflow-hidden faq-item"
              data-q={faq.question.toLowerCase()}
            >
              <summary class="flex items-start justify-between gap-3 px-5 py-4 cursor-pointer list-none hover:bg-surface2 transition-colors">
                <span class="text-sm font-medium">{faq.question}</span>
                <span class="text-muted flex-shrink-0 mt-0.5 group-open:rotate-180 transition-transform duration-200 text-xs">▾</span>
              </summary>
              <div class="px-5 pb-5 pt-3 text-sm text-muted leading-relaxed border-t border-border bg-surface2/30">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}

    <!-- CTA -->
    <div class="mt-12 text-center bg-surface border border-border rounded-xl p-8">
      <h3 class="font-medium mb-2">Başka sorunuz var mı?</h3>
      <p class="text-sm text-muted mb-4">
        Anthropic'in resmi belgelerini incelemeyi deneyebilirsiniz.
      </p>
      <a
        href="https://docs.anthropic.com"
        target="_blank"
        rel="noopener"
        class="inline-block bg-accent hover:bg-accent-light text-white text-sm px-5 py-2.5 rounded-lg no-underline transition-colors"
      >
        Anthropic Docs →
      </a>
    </div>

  </div>
</BaseLayout>

<script>
  const input = document.getElementById('faq-search') as HTMLInputElement;
  const items = document.querySelectorAll<HTMLElement>('.faq-item');

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase();
    items.forEach(item => {
      const match = !q || (item.dataset.q ?? '').includes(q);
      item.style.display = match ? '' : 'none';
    });
  });
</script>
